# ============================================================
# Secrets & credentials (NEVER commit these)
# ============================================================
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.crt
*.p12
*.jks
*.keystore
*.pfx
secrets/
vault-token
kubeconfig
*.secret
*.secrets
service-account*.json
credentials.json
*-credentials.json

# ============================================================
# IDE / Editor
# ============================================================
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
*.launch
# VS Code — keep shared workspace settings, ignore personal
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.vscode/*.code-workspace
# Keep extensions.json so teammates get recommended extensions
!.vscode/extensions.json
*.sublime-project
*.sublime-workspace

